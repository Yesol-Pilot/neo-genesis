    {
      "id": "H011",
      "type": "hook_exit",
      "severity": "P0",
      "hook": "pre_tool_use.ps1",
      "stdin": {"tool_name": "Bash", "tool_input": {"command": "rm -rf /"}},
      "expect_exit": 2,
      "stdout_contains": ["\"decision\":\"block\"", "rm -rf"]
    },
    {
      "id": "H012",
      "type": "hook_exit",
      "severity": "P0",
      "hook": "pre_tool_use.ps1",
      "stdin": {"tool_name": "Bash", "tool_input": {"command": "git push --force origin master"}},
      "expect_exit": 2,
      "stdout_contains": ["\"decision\":\"block\"", "force push"]
    },
    {
      "id": "H013",
      "type": "hook_exit",
      "severity": "P1",
      "hook": "pre_tool_use.ps1",
      "stdin": {"tool_name": "Bash", "tool_input": {"command": "git push --force-with-lease origin master"}},
      "expect_exit": 0,
      "stdout_not_contains": ["\"decision\":\"block\""]
    },
    {
      "id": "H014",
      "type": "hook_exit",
      "severity": "P0",
      "hook": "pre_tool_use.ps1",
      "stdin": {"tool_name": "Bash", "tool_input": {"command": "psql -c \"DROP TABLE users\""}},
      "expect_exit": 2,
      "stdout_contains": ["\"decision\":\"block\"", "DROP TABLE"]
    },
    {
